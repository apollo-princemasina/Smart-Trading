# ══════════════════════════════════════════════════════════════
#  MFIP — Moonshot Forex Intelligence Platform
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# Local dev (no Docker):     leave as SQLite (default, no config needed)
# Local dev (Docker):        set to postgresql+asyncpg://mfip_user:mfip_pass@localhost:5432/mfip
# Railway production:        Railway injects DATABASE_URL automatically
DATABASE_URL=sqlite+aiosqlite:///./data/mfip.db

# ── Twelve Data ───────────────────────────────────────────────
TWELVE_DATA_API_KEY=d0cd8527748f45f0b0ee8f02791feedb

# ── Rolling Buffer ────────────────────────────────────────────
BUFFER_M15_SIZE=800
BUFFER_H1_SIZE=500
BUFFER_H4_SIZE=300
BUFFER_D1_SIZE=200
BUFFER_W1_SIZE=100

# Transient restart cache (NOT a database — auto-expires after TTL hours)
BUFFER_CACHE_ENABLED=true
BUFFER_CACHE_TTL_HOURS=4.0

# ── Model ─────────────────────────────────────────────────────
MODEL_BUNDLE_DIR=models/best_model
MODEL_SYMBOL=EURUSD

# ── Inference ─────────────────────────────────────────────────
INFERENCE_MIN_CONFIDENCE=0.60
INFERENCE_SPREAD_FILL=15
INFERENCE_TP_ATR_MULT=3.0
INFERENCE_SL_ATR_MULT=1.5

# ── MT5 (optional — for backtesting comparison only) ──────────
MT5_LOGIN=109078903
MT5_PASSWORD=ZzU@Q2Vl
MT5_SERVER=MetaQuotes-Demo
